@using Quick.Fields

<InputBase Field="@Field">
    @if (Field.Input_ReadOnly.HasValue && Field.Input_ReadOnly.Value)
    {
        <InputTextArea class="@ControlUtils.GetInputClass(Field)" @bind-Value="@Field.Value" placeholder="@Field.Input_Placeholder" rows="@(Field.InputTextArea_Rows == null ? 10 : Field.InputTextArea_Rows.Value)" readonly />
    }
    else
    {
        <InputTextArea class="@ControlUtils.GetInputClass(Field)" @bind-Value="@Field.Value" placeholder="@Field.Input_Placeholder" rows="@(Field.InputTextArea_Rows == null ? 10 : Field.InputTextArea_Rows.Value)" />
    }
</InputBase>
     
@code
{
    [Parameter]
    public FieldForGet Field { get; set; }
}