@using Quick.Fields

<InputBase Field="@Field">
    @if (Field.Input_ReadOnly.HasValue && Field.Input_ReadOnly.Value)
    {
        <InputText type="password" class="@ControlUtils.GetInputClass(Field)" @bind-Value="@Field.Value" placeholder="@Field.Input_Placeholder" readonly />
    }
    else
    {
        <InputText type="password" class="@ControlUtils.GetInputClass(Field)" @bind-Value="@Field.Value" placeholder="@Field.Input_Placeholder" />
    }
</InputBase>

@code
{
    [Parameter]
    public FieldForGet Field { get; set; }
}