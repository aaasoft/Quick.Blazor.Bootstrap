@using Quick.Fields

<InputBase Field="@Field">
    <div class="custom-control custom-switch">
        @if (Field.Input_ReadOnly.HasValue && Field.Input_ReadOnly.Value)
        {
            <InputCheckbox class="custom-control-input" @bind-Value="Value" id="@id" disabled />
        }
        else
        {
            <InputCheckbox class="custom-control-input" @bind-Value="Value" id="@id" />
        }
        <label class="custom-control-label" for="@id"></label>
    </div>
</InputBase>

@code
{
    private string id = "checkbox_" + Guid.NewGuid().ToString("N");
    [Parameter]
    public FieldForGet Field { get; set; }

    private bool Value
    {
        get
        {
            if (bool.TryParse(Field.Value, out var ret))
                return ret;
            return false;
        }
        set
        {
            Field.Value = value.ToString();
        }
    }
}