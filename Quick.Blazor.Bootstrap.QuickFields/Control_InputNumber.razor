@using Quick.Fields

<InputBase Field="@Field">
@if (Field.Input_ReadOnly.HasValue && Field.Input_ReadOnly.Value)
{
    <input type="number" class="@ControlUtils.GetInputClass(Field)" @bind="@Field.Value"
        placeholder="@Field.Input_Placeholder" readonly>
}
else
{
    <input type="number" class="@ControlUtils.GetInputClass(Field)" @bind="@Field.Value"
        placeholder="@Field.Input_Placeholder">
}
</InputBase>

@code
{
    [Parameter]
    public FieldForGet Field { get; set; }
}